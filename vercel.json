{
    "version": 2,
    "framework": "laravel",
    "builds": [
        {
            "src": "public/index.php",
            "use": "@vercel/php@0.6.0"
        }
    ],
    "routes": [
        {
            "src": "^/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "^/(css|js|images|favicon.ico)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ]
}
