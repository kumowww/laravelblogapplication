{
  "version": 2,
  "installCommand": "composer install",
  "buildCommand": "php artisan route:clear && php artisan config:clear && php artisan view:clear",
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php"
    }
  ],
  "routes": [
    {
      "src": "/(css|js|images|fonts)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}